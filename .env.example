# Local development variables. Streamlit Cloud uses .streamlit/secrets.toml instead.

DATABASE_URL=
APP_BASE_URL=http://localhost:8501

OPENAI_API_KEY=
OPENAI_MODERATION_MODEL=omni-moderation-latest

STUN_URLS=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# Local development only. Production should use Neon/PostgreSQL DATABASE_URL.
ZOET_ALLOW_SQLITE_FALLBACK=true
