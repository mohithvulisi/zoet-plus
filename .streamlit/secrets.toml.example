# Copy this file to .streamlit/secrets.toml for local Streamlit development.
# In Streamlit Community Cloud, add these keys in App settings > Secrets.

# Neon PostgreSQL is recommended for production.
# Example:
# DATABASE_URL = "postgresql://user:password@ep-example.us-east-2.aws.neon.tech/zoetplus?sslmode=require"
DATABASE_URL = ""

# Public base URL used to generate join links after deployment.
# Example:
# APP_BASE_URL = "https://your-zoet-plus-app.streamlit.app"
APP_BASE_URL = "http://localhost:8501"

# Optional OpenAI moderation. If absent or blank, moderation is gracefully disabled.
OPENAI_API_KEY = ""
OPENAI_MODERATION_MODEL = "omni-moderation-latest"

# WebRTC ICE configuration.
STUN_URLS = "stun:stun.l.google.com:19302"
TURN_URL = ""
TURN_USERNAME = ""
TURN_CREDENTIAL = ""

# Local development only. Production should set DATABASE_URL.
ZOET_ALLOW_SQLITE_FALLBACK = "true"
